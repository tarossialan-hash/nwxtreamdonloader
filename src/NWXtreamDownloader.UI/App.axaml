<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="NWXtreamDownloader.UI.App"
             RequestedThemeVariant="Dark">

    <Application.Resources>
        <!-- Cor de destaque (violeta moderna) usada por botões accent, seleção etc. -->
        <Color x:Key="SystemAccentColor">#6C5CE7</Color>
        <Color x:Key="SystemAccentColorDark1">#5B4CD6</Color>
        <Color x:Key="SystemAccentColorDark2">#4C3EC2</Color>
        <Color x:Key="SystemAccentColorDark3">#3E32A8</Color>
        <Color x:Key="SystemAccentColorLight1">#8B7FF0</Color>
        <Color x:Key="SystemAccentColorLight2">#A79DF5</Color>
        <Color x:Key="SystemAccentColorLight3">#C3BCF9</Color>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://NWXtreamDownloader/Styles.axaml" />
    </Application.Styles>
</Application>
